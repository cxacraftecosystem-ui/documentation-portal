# For Supabase Postgres, replace this with the Supabase pooled or direct PostgreSQL connection string.
# The Supabase REST URL is not a Prisma DATABASE_URL.
# Set this to the Supabase SESSION pooler URL (...pooler.supabase.com:5432). Migrations need it
# (session mode = advisory locks/DDL). The running app automatically re-routes ITS queries to the
# TRANSACTION pooler (:6543, pgbouncer=true) — see DATABASE_USE_TRANSACTION_POOLER below — so a
# couple of workers can't exhaust the 15-connection session pool (EMAXCONNSESSION).
DATABASE_URL=postgresql://postgres:postgres@localhost:55432/field_repository
# Runtime pooling (Supabase only; ignored for non-pooler/local URLs). Defaults are sensible.
# DATABASE_USE_TRANSACTION_POOLER=true   # set false to keep runtime on the session pooler
# DATABASE_CONNECTION_LIMIT=40           # max client connections per uvicorn worker
# DATABASE_POOL_TIMEOUT=10               # seconds to wait for a pooled connection (Prisma default)
JWT_SECRET=change-this-to-a-long-random-secret
JWT_EXPIRES_MINUTES=10080

AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_REGION=us-east-1
AWS_S3_BUCKET=field-repository
AWS_S3_ENDPOINT=http://localhost:9000
AWS_S3_PUBLIC_BASE_URL=http://localhost:9000/field-repository

NEXT_PUBLIC_APP_URL=http://localhost:3000
BACKEND_CORS_ORIGINS=http://localhost:3000

# Optional Google OAuth support
GOOGLE_CLIENT_ID=
GOOGLE_ANDROID_CLIENT_ID=
MASTER_ADMIN_EMAIL=ankits1802@gmail.com
MASTER_ADMIN_NAME=Ankit Kumar

# Optional AI-assisted media processing
OPENAI_API_KEY=
OPENAI_TRANSCRIPTION_MODEL=whisper-1
# Single Gemini key (legacy) and/or a rotating pool of keys. GEMINI_API_KEYS accepts any number
# of comma- or newline-separated keys; the measurement worker round-robins and fails over across
# them. Add more keys here at any time without changing code.
GEMINI_API_KEY=
GEMINI_API_KEYS=
NEXT_PUBLIC_MAPTILER_API_KEY=

# Optional Supabase metadata for deployments that also need REST/Admin access.
# Keep SUPABASE_SECRET_KEY in private runtime secrets only.
SUPABASE_REST_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=

# Optional seed values used by scripts/seed_admin.py
ADMIN_EMAIL=admin@example.com
ADMIN_NAME=Repository Admin
ADMIN_PASSWORD=
