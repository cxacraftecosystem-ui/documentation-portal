generator client {
  provider                    = "prisma-client-py"
  interface                   = "asyncio"
  recursive_type_depth        = 5
  enable_experimental_decimal = true
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  MASTER_ADMIN
  ADMIN
  RESEARCHER
}

enum AuthProvider {
  LOCAL
  GOOGLE
}

enum RecordStatus {
  DRAFT
  PENDING
  APPROVED
  REJECTED
}

enum MediaType {
  IMAGE
  VIDEO
  AUDIO
  PDF
  DOCUMENT
  OTHER
}

enum ProductType {
  FINISHED_GOOD
  SAMPLE
  RAW_MATERIAL
  COMPONENT
  PACKAGING
  OTHER
}

enum MarketDemand {
  LOW
  MEDIUM
  HIGH
  SEASONAL
  UNKNOWN
}

enum MakerType {
  ARTISAN
  LOCAL_BLACKSMITH
  CARPENTER
  WORKSHOP
  FACTORY
  UNKNOWN
  OTHER
}

enum TraditionType {
  TRADITIONAL
  MODERN
  HYBRID
  UNKNOWN
}

enum ReviewRecordType {
  ARTISAN
  WORKSHOP
  PRODUCT
  TOOL
  MEDIA
}

enum MediaProcessingJobType {
  TRANSCRIPTION
  MEASUREMENT
}

enum MediaProcessingJobStatus {
  QUEUED
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
}

enum ProcessStepType {
  SEQUENTIAL
  GROUP
}

model User {
  id           String       @id @default(cuid())
  email        String       @unique
  name         String
  passwordHash String?
  avatarUrl    String?
  role         UserRole     @default(RESEARCHER)
  authProvider AuthProvider @default(LOCAL)
  canManageQuestionnaire Boolean @default(false)
  canManageCrafts        Boolean @default(false)
  canManageWorkshops     Boolean @default(false)
  canReview              Boolean @default(false)
  canViewProvenance      Boolean @default(false)
  canDownloadDataset     Boolean @default(false)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  artisans  Artisan[]              @relation("ArtisanCreatedBy")
  crafts    Craft[]                @relation("CraftCreatedBy")
  workshops Workshop[]             @relation("WorkshopCreatedBy")
  products  ProductDocumentation[] @relation("ProductCreatedBy")
  tools     ToolDocumentation[]    @relation("ToolCreatedBy")
  processes Process[]              @relation("ProcessCreatedBy")
  media     MediaFile[]            @relation("MediaUploadedBy")
  requestedMediaProcessingJobs MediaProcessingJob[] @relation("MediaProcessingRequestedBy")
  reviews   ReviewLog[]            @relation("ReviewReviewer")
  questionnaireInterviews QuestionnaireInterview[] @relation("QuestionnaireCreatedBy")
  questionnaireResponses QuestionnaireResponse[] @relation("QuestionnaireAnsweredBy")
  appReleases AppRelease[] @relation("AppReleasePublishedBy")
  feedback    Feedback?    @relation("FeedbackUser")
  sectionStatusesSet QuestionnaireSectionStatus[] @relation("SectionStatusSetBy")

  @@index([role])
  @@index([canManageQuestionnaire])
}

/// One piece of app feedback per user: a quantitative rating (1–5) plus a qualitative comment.
/// Upserted, so a user can revisit and update their feedback at any time. The master admin reviews
/// everyone's feedback on the View Data screen.
model Feedback {
  id        String   @id @default(cuid())
  userId    String   @unique
  // Quantitative (each 1–5). `rating` is the overall score; the rest are per-aspect sub-ratings.
  rating        Int?
  easeOfUse     Int?
  reliability   Int?
  performance   Int?
  design        Int?
  features      Int?
  recommend     Int?
  // Qualitative free text. `comment` is the general note; the rest are targeted prompts.
  comment         String?
  likeMost        String?
  improve         String?
  bugs            String?
  featureRequests String?
  role            String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation("FeedbackUser", fields: [userId], references: [id], onDelete: Cascade)

  @@index([updatedAt])
}

/// A published Android app build that the master admin pushed out as an over-the-air update. The
/// highest versionCode is the current release; clients compare their installed versionCode and
/// self-update from `url`.
model AppRelease {
  id            String   @id @default(cuid())
  versionCode   Int
  versionName   String
  objectKey     String
  url           String?
  notes         String?
  publishedById String?
  publishedBy   User?    @relation("AppReleasePublishedBy", fields: [publishedById], references: [id], onDelete: SetNull)
  publishedAt   DateTime @default(now())

  @@index([versionCode])
}

model Craft {
  id            String   @id @default(cuid())
  name          String   @unique
  localName     String?
  category      String?
  description   String?
  place         String?
  extraMetadata Json?
  recordedAt    DateTime @default(now())
  recordedTimezone String @default("Asia/Kolkata")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  createdById   String?

  createdBy User?                  @relation("CraftCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  artisans  Artisan[]
  products  ProductDocumentation[]
  tools     ToolDocumentation[]
  media     MediaFile[]
  workshops WorkshopCraft[]

  @@index([name])
  @@index([place])
  @@index([recordedAt])
}

model Location {
  id            String   @id @default(cuid())
  latitude      Float
  longitude     Float
  altitude      Float?
  accuracy      Float?
  address       String?
  placeName     String?
  capturedAt    DateTime?
  extraMetadata Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  artisans  Artisan[]
  workshops Workshop[]
  products  ProductDocumentation[]
  tools     ToolDocumentation[]
  media     MediaFile[]
  questionnaireInterviews QuestionnaireInterview[]

  @@index([latitude, longitude])
  @@index([placeName])
}

model Artisan {
  id            String       @id @default(cuid())
  name          String
  localName     String?
  gender        String?
  phone         String?
  email         String?
  place         String
  address       String?
  notes         String?
  // Newline-separated, numbered guidance for working with this artisan: dos = positive prompt (what to
  // do / emphasise), donts = negative prompt (what to avoid). Required on new records; nullable so the
  // existing rows from before this field can be backfilled later instead of blocking the migration.
  dos           String?
  donts         String?
  status        RecordStatus @default(PENDING)
  reviewNotes   String?
  reviewedById  String?
  reviewedAt    DateTime?
  extraMetadata Json?
  recordedAt    DateTime     @default(now())
  recordedTimezone String    @default("Asia/Kolkata")
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  craftId       String?
  locationId    String?
  createdById   String

  craft     Craft?                 @relation(fields: [craftId], references: [id], onDelete: SetNull)
  location  Location?              @relation(fields: [locationId], references: [id], onDelete: SetNull)
  createdBy User                   @relation("ArtisanCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  workshops WorkshopArtisan[]
  products  ProductDocumentation[]
  tools     ToolDocumentation[]
  toolLinks ToolArtisan[]
  media     MediaFile[]
  questionnaireInterviews QuestionnaireInterviewArtisan[]
  sectionStatuses QuestionnaireSectionStatus[]

  @@index([name])
  @@index([place])
  @@index([craftId])
  @@index([createdById])
  @@index([status])
  @@index([recordedAt])
}

model Workshop {
  id            String       @id @default(cuid())
  title         String
  date          DateTime
  startDate     DateTime?
  endDate       DateTime?
  place         String
  description   String?
  notes         String?
  status        RecordStatus @default(PENDING)
  reviewNotes   String?
  reviewedById  String?
  reviewedAt    DateTime?
  extraMetadata Json?
  recordedAt    DateTime     @default(now())
  recordedTimezone String    @default("Asia/Kolkata")
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  locationId    String?
  createdById   String

  location  Location?              @relation(fields: [locationId], references: [id], onDelete: SetNull)
  createdBy User                   @relation("WorkshopCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  artisans  WorkshopArtisan[]
  crafts    WorkshopCraft[]
  products  ProductDocumentation[]
  tools     ToolDocumentation[]
  media     MediaFile[]

  @@index([date])
  @@index([startDate])
  @@index([endDate])
  @@index([place])
  @@index([createdById])
  @@index([status])
  @@index([recordedAt])
}

model WorkshopArtisan {
  workshopId String
  artisanId  String
  role       String?
  createdAt  DateTime @default(now())

  workshop Workshop @relation(fields: [workshopId], references: [id], onDelete: Cascade)
  artisan  Artisan  @relation(fields: [artisanId], references: [id], onDelete: Cascade)

  @@id([workshopId, artisanId])
  @@index([artisanId])
}

model WorkshopCraft {
  workshopId String
  craftId    String
  createdAt  DateTime @default(now())

  workshop Workshop @relation(fields: [workshopId], references: [id], onDelete: Cascade)
  craft    Craft    @relation(fields: [craftId], references: [id], onDelete: Cascade)

  @@id([workshopId, craftId])
  @@index([craftId])
}

model ProductDocumentation {
  id                         String       @id @default(cuid())
  craftName                  String
  place                      String
  artisanName                String
  productName                String
  localName                  String?
  productType                ProductType  @default(OTHER)
  timeTakenToCompleteProduct String?
  size                       String?
  lengthInches               Decimal?     @db.Decimal(10, 2)
  breadthInches              Decimal?     @db.Decimal(10, 2)
  heightInches               Decimal?     @db.Decimal(10, 2)
  measurementImageId         String?
  measurementAnalysis        Json?
  measurementAnalysisStatus  String?
  costOfMaking               Decimal?     @db.Decimal(12, 2)
  sellingPrice               Decimal?     @db.Decimal(12, 2)
  marketDemand               MarketDemand @default(UNKNOWN)
  rawMaterialsUsed           String?
  mainToolsUsed              String?
  productFunctionUse         String?
  remarks                    String?
  status                     RecordStatus @default(PENDING)
  reviewNotes                String?
  reviewedById               String?
  reviewedAt                 DateTime?
  extraMetadata              Json?
  recordedAt                 DateTime     @default(now())
  recordedTimezone           String       @default("Asia/Kolkata")
  createdAt                  DateTime     @default(now())
  updatedAt                  DateTime     @updatedAt
  artisanId                  String?
  craftId                    String?
  workshopId                 String?
  locationId                 String?
  createdById                String

  artisan   Artisan?    @relation(fields: [artisanId], references: [id], onDelete: SetNull)
  craft     Craft?      @relation(fields: [craftId], references: [id], onDelete: SetNull)
  workshop  Workshop?   @relation(fields: [workshopId], references: [id], onDelete: SetNull)
  location  Location?   @relation(fields: [locationId], references: [id], onDelete: SetNull)
  createdBy User        @relation("ProductCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  media     MediaFile[]
  mediaProcessingJobs MediaProcessingJob[]
  processes Process[]

  @@index([productName])
  @@index([craftName])
  @@index([place])
  @@index([artisanName])
  @@index([artisanId])
  @@index([craftId])
  @@index([workshopId])
  @@index([createdById])
  @@index([status])
  @@index([recordedAt])
}

model ToolDocumentation {
  id                            String        @id @default(cuid())
  craftName                     String
  place                         String
  artisanName                   String
  toolkitName                   String
  localName                     String?
  englishName                   String?
  processUsedIn                 String?
  material                      String?
  yearsInUse                    Int?
  height                        Decimal?      @db.Decimal(10, 2)
  width                         Decimal?      @db.Decimal(10, 2)
  lengthInches                  Decimal?      @db.Decimal(10, 2)
  breadthInches                 Decimal?      @db.Decimal(10, 2)
  measurementImageId            String?
  measurementAnalysis           Json?
  measurementAnalysisStatus     String?
  thickness                     Decimal?      @db.Decimal(10, 2)
  weight                        Decimal?      @db.Decimal(10, 2)
  radius                        Decimal?      @db.Decimal(10, 2)
  maker                         MakerType     @default(UNKNOWN)
  traditionType                 TraditionType @default(UNKNOWN)
  replacementCost               Decimal?      @db.Decimal(12, 2)
  suggestionsForToolImprovement String?
  remarks                       String?
  status                        RecordStatus  @default(PENDING)
  reviewNotes                   String?
  reviewedById                  String?
  reviewedAt                    DateTime?
  extraMetadata                 Json?
  recordedAt                    DateTime      @default(now())
  recordedTimezone              String        @default("Asia/Kolkata")
  createdAt                     DateTime      @default(now())
  updatedAt                     DateTime      @updatedAt
  artisanId                     String?
  craftId                       String?
  workshopId                    String?
  locationId                    String?
  createdById                   String

  artisan   Artisan?    @relation(fields: [artisanId], references: [id], onDelete: SetNull)
  craft     Craft?      @relation(fields: [craftId], references: [id], onDelete: SetNull)
  workshop  Workshop?   @relation(fields: [workshopId], references: [id], onDelete: SetNull)
  location  Location?   @relation(fields: [locationId], references: [id], onDelete: SetNull)
  createdBy User        @relation("ToolCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  media     MediaFile[]
  mediaProcessingJobs MediaProcessingJob[]
  artisanLinks ToolArtisan[]

  @@index([toolkitName])
  @@index([craftName])
  @@index([place])
  @@index([artisanName])
  @@index([artisanId])
  @@index([craftId])
  @@index([workshopId])
  @@index([createdById])
  @@index([status])
  @@index([recordedAt])
}

// Many-to-many between a tool and the artisans who use it. Lets one documented tool be assigned to
// several artisans (across the same or different crafts) instead of re-entering the tool per craft.
model ToolArtisan {
  id        String   @id @default(cuid())
  toolId    String
  artisanId String
  createdAt DateTime @default(now())

  tool    ToolDocumentation @relation(fields: [toolId], references: [id], onDelete: Cascade)
  artisan Artisan           @relation(fields: [artisanId], references: [id], onDelete: Cascade)

  @@unique([toolId, artisanId])
  @@index([toolId])
  @@index([artisanId])
}

model MediaFile {
  id               String       @id @default(cuid())
  originalFilename String
  mediaType        MediaType
  mimeType         String
  sizeBytes        BigInt
  bucket           String
  objectKey        String       @unique
  url              String?
  caption          String?
  checksum         String?
  transcriptText   String?
  transcriptSummary String?
  transcriptStatus String?
  transcriptError  String?
  linkedRecordType String?
  linkedRecordId   String?
  status           RecordStatus @default(PENDING)
  reviewNotes      String?
  reviewedById     String?
  reviewedAt       DateTime?
  extraMetadata    Json?
  recordedAt       DateTime     @default(now())
  recordedTimezone String       @default("Asia/Kolkata")
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  uploadedById     String
  artisanId        String?
  craftId          String?
  workshopId       String?
  productId        String?
  toolId           String?
  questionnaireInterviewId String?
  locationId       String?

  uploadedBy User                  @relation("MediaUploadedBy", fields: [uploadedById], references: [id], onDelete: Restrict)
  artisan    Artisan?              @relation(fields: [artisanId], references: [id], onDelete: SetNull)
  craft      Craft?                @relation(fields: [craftId], references: [id], onDelete: SetNull)
  workshop   Workshop?             @relation(fields: [workshopId], references: [id], onDelete: SetNull)
  product    ProductDocumentation? @relation(fields: [productId], references: [id], onDelete: SetNull)
  tool       ToolDocumentation?    @relation(fields: [toolId], references: [id], onDelete: SetNull)
  questionnaireInterview QuestionnaireInterview? @relation("QuestionnaireMedia", fields: [questionnaireInterviewId], references: [id], onDelete: SetNull)
  location   Location?             @relation(fields: [locationId], references: [id], onDelete: SetNull)
  processingJobs MediaProcessingJob[]

  @@index([mediaType])
  @@index([uploadedById])
  @@index([craftId])
  @@index([linkedRecordType, linkedRecordId])
  @@index([questionnaireInterviewId])
  @@index([createdAt])
  @@index([status])
  @@index([recordedAt])
}

model MediaProcessingJob {
  id             String                   @id @default(cuid())
  jobType        MediaProcessingJobType
  status         MediaProcessingJobStatus @default(QUEUED)
  priority       Int                      @default(100)
  attempts       Int                      @default(0)
  maxAttempts    Int                      @default(3)
  error          String?
  result         Json?
  lockedAt       DateTime?
  lockedBy       String?
  runAfter       DateTime                 @default(now())
  startedAt      DateTime?
  completedAt    DateTime?
  createdAt      DateTime                 @default(now())
  updatedAt      DateTime                 @updatedAt
  mediaFileId    String
  requestedById  String?
  productId      String?
  toolId         String?

  mediaFile   MediaFile              @relation(fields: [mediaFileId], references: [id], onDelete: Cascade)
  requestedBy User?                  @relation("MediaProcessingRequestedBy", fields: [requestedById], references: [id], onDelete: SetNull)
  product     ProductDocumentation?  @relation(fields: [productId], references: [id], onDelete: SetNull)
  tool        ToolDocumentation?     @relation(fields: [toolId], references: [id], onDelete: SetNull)

  @@index([status, runAfter, priority, createdAt])
  @@index([mediaFileId])
  @@index([requestedById])
  @@index([productId])
  @@index([toolId])
}

model QuestionnaireSection {
  id        String   @id @default(cuid())
  code      String   @unique
  title     String
  sortOrder Int
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  questions QuestionnaireQuestion[]
  sectionStatuses QuestionnaireSectionStatus[]

  @@unique([sortOrder])
  @@index([code])
  @@index([isActive, sortOrder])
}

/// Admin-set completion status for one (artisan, section) cell on the "Check completion" matrix.
/// Absent row = no manual override (the matrix then falls back to data-derived completion). A row
/// here is an explicit verdict by an admin/master admin that overrides the derived green.
model QuestionnaireSectionStatus {
  id        String   @id @default(cuid())
  artisanId String
  sectionId String
  // COMPLETED (green) | NEEDS_REVIEW (yellow) | NEEDS_REDO (red).
  status    String
  setById   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  artisan Artisan              @relation(fields: [artisanId], references: [id], onDelete: Cascade)
  section QuestionnaireSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  setBy   User                 @relation("SectionStatusSetBy", fields: [setById], references: [id], onDelete: Restrict)

  @@unique([artisanId, sectionId])
  @@index([artisanId])
  @@index([sectionId])
}

model QuestionnaireQuestion {
  id          String   @id @default(cuid())
  sectionCode String
  sectionTitle String
  prompt      String
  sortOrder   Int
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  sectionId   String?

  section   QuestionnaireSection? @relation(fields: [sectionId], references: [id], onDelete: SetNull)
  responses QuestionnaireResponse[]

  @@index([sectionCode])
  @@index([sectionId])
  @@index([isActive])
}

model QuestionnaireInterview {
  id            String       @id @default(cuid())
  title         String
  interviewDate DateTime?
  place         String?
  language      String?
  notes         String?
  status        RecordStatus @default(PENDING)
  extraMetadata Json?
  recordedAt    DateTime     @default(now())
  recordedTimezone String    @default("Asia/Kolkata")
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  createdById   String
  locationId    String?
  // Deterministic key for the exact set of artisans this interview covers (sorted, comma-joined
  // artisan ids). Enforces ONE interview per artisan set: creation is idempotent on this key, so
  // every client lands on the single canonical entry instead of spawning duplicates. NULL only when
  // an interview has no artisans (those are not deduped). A subset is a different set => different key.
  artisanSetKey String?      @unique

  createdBy User                             @relation("QuestionnaireCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  location  Location?                        @relation(fields: [locationId], references: [id], onDelete: SetNull)
  artisans  QuestionnaireInterviewArtisan[]
  responses QuestionnaireResponse[]
  media     MediaFile[]                      @relation("QuestionnaireMedia")

  @@index([createdById])
  @@index([status])
  @@index([interviewDate])
  @@index([recordedAt])
}

model QuestionnaireInterviewArtisan {
  interviewId String
  artisanId   String
  createdAt   DateTime @default(now())

  interview QuestionnaireInterview @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  artisan   Artisan                @relation(fields: [artisanId], references: [id], onDelete: Cascade)

  @@id([interviewId, artisanId])
  @@index([artisanId])
}

model QuestionnaireResponse {
  id          String   @id @default(cuid())
  interviewId String
  questionId  String
  answerText  String?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  answeredById String

  interview  QuestionnaireInterview @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  question   QuestionnaireQuestion  @relation(fields: [questionId], references: [id], onDelete: Restrict)
  answeredBy User                   @relation("QuestionnaireAnsweredBy", fields: [answeredById], references: [id], onDelete: Restrict)

  @@unique([interviewId, questionId])
  @@index([questionId])
  @@index([answeredById])
}

model Process {
  id                  String       @id @default(cuid())
  name                String
  preProcessAvailable Boolean      @default(false)
  notes               String?
  status              RecordStatus @default(PENDING)
  reviewNotes         String?
  reviewedById        String?
  reviewedAt          DateTime?
  extraMetadata       Json?
  recordedAt          DateTime     @default(now())
  recordedTimezone    String       @default("Asia/Kolkata")
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt
  productId           String
  createdById         String

  product   ProductDocumentation @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdBy User                 @relation("ProcessCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  steps     ProcessStep[]

  @@index([productId])
  @@index([createdById])
  @@index([status])
  @@index([recordedAt])
}

model ProcessStep {
  id        String          @id @default(cuid())
  processId String
  name      String
  stepType  ProcessStepType @default(SEQUENTIAL)
  sortOrder Int
  notes     String?
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  process Process @relation(fields: [processId], references: [id], onDelete: Cascade)

  @@index([processId])
}

model ReviewLog {
  id         String           @id @default(cuid())
  recordType ReviewRecordType
  recordId   String
  status     RecordStatus
  notes      String?
  reviewerId String
  createdAt  DateTime         @default(now())

  reviewer User @relation("ReviewReviewer", fields: [reviewerId], references: [id], onDelete: Restrict)

  @@index([recordType, recordId])
  @@index([reviewerId])
  @@index([createdAt])
}

// Singleton row (id = "singleton") holding master-admin-configurable global settings. For now: how
// audio transcripts are produced (raw / refined / refined+translated) and an optional off-peak window
// during which the heavy transcription+refinement work runs, so it doesn't compete with daytime
// uploads. Extend with more configurable fields over time.
model AppSetting {
  id                 String   @id @default("singleton")
  transcriptionMode  String   @default("REFINED_TRANSLATED")
  batchWindowEnabled Boolean  @default(false)
  batchWindowStart   String   @default("02:00")
  batchWindowEnd     String   @default("05:00")
  batchTimezone      String   @default("Asia/Kolkata")
  updatedAt          DateTime @updatedAt
  updatedById        String?
}
